# Copy this file to ".env" and fill in real values. Do NOT commit ".env".

# === Server ===
PORT=3000

# CORS whitelist (Phase 5) — danh sách origin được phép gọi API, ngăn cách bằng dấu phẩy.
# Bỏ trống => dùng default dev: http://localhost:3000, http://127.0.0.1:3000,
# http://localhost:5500, http://127.0.0.1:5500. Production: đặt origin thật của client.
ALLOWED_ORIGINS=

# === SQL Server ===
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# === Firebase Admin SDK ===
# Path to the service account JSON (Firebase Console -> Service accounts).
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# === Admin tự động (Phase 5) ===
# Email đăng nhập nào khớp danh sách này sẽ TỰ ĐỘNG được gán role='admin' trong DB
# (không cần chạy SQL thủ công). Nhiều email thì ngăn cách bằng dấu phẩy.
# Để trống nếu chỉ muốn cấp quyền thủ công qua db/set-role.js hoặc db/make-admin.sql.
ADMIN_EMAILS=
